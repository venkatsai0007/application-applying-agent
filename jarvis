#!/bin/bash

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color
BOLD='\033[1m'

print_banner() {
    echo -e "${CYAN}${BOLD}"
    echo '      ___               _   _        _                _       '
    echo '     / _ \             | | (_)      / \              | |      '
    echo '    / /_\ \__ _  ___ _ __| |_ ___   / _ \  _ __  _ __ | |_   _ '
    echo '    |  _  / _` |/ _ \ '\''__| __/ __| / ___ \| '\''_ \| '\''_ \| | | | |'
    echo '    | | | \(_| |  __/ |  | |_\__ \/ ___  \ |_) | |_) | | |_| |'
    echo '    \_| |_/\__, |\___|_|   \__|___/_/   \_\ .__/| .__/|_|\__, |'
    echo '            __/ |                         | |   | |       __/ |'
    echo '           |___/                          |_|   |_|      |___/ '
    echo -e "${NC}"
    echo -e "${BLUE}================================================================${NC}"
    echo -e "${GREEN}  Your AI-Powered Job Application Assistant is ready.${NC}"
    echo -e "${BLUE}================================================================${NC}"
    echo ""
}

show_help() {
    print_banner
    echo -e "${BOLD}Usage:${NC} ./jarvis [COMMAND]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo -e "  ${GREEN}up${NC}      🚀 Build and start the agent in the background"
    echo -e "  ${YELLOW}down${NC}    🛑 Gracefully stop the agent"
    echo -e "  ${RED}kill${NC}    💀 Force stop and remove all containers for this project"
    echo -e "  ${CYAN}logs${NC}    📜 View the live logs of the agent"
    echo -e "  ${BLUE}help${NC}    ℹ️  Show this help message"
    echo ""
}

if [ "$1" == "up" ]; then
    print_banner
    echo -e "${CYAN}🔍 Checking for existing Agentic Apply images...${NC}"
    
    IMAGE_EXISTS=$(docker images -q "*backend*" 2> /dev/null)
    
    if [ ! -z "$IMAGE_EXISTS" ]; then
        echo -e "${YELLOW}⚠️  Docker images already exist.${NC}"
        read -p "Do you want to rebuild them? (y/N): " rebuild
        if [[ "$rebuild" =~ ^[Yy]$ ]]; then
            echo -e "${GREEN}⚙️  Starting with rebuild...${NC}"
            docker compose up -d --build
        else
            echo -e "${GREEN}🚀 Starting without rebuild...${NC}"
            docker compose up -d
        fi
    else
        echo -e "${GREEN}⚙️  Building and starting Agentic Apply (Jarvis)...${NC}"
        docker compose up -d --build
    fi
    echo ""
    echo -e "${GREEN}✅ Jarvis is up and running!${NC}"
    echo -e "🌍 Access the UI at: ${BOLD}http://localhost:5173${NC}"

elif [ "$1" == "down" ]; then
    echo -e "${YELLOW}🛑 Stopping Jarvis gracefully...${NC}"
    docker compose down
    echo -e "${GREEN}✅ Jarvis has been stopped.${NC}"

elif [ "$1" == "kill" ]; then
    echo -e "${RED}💀 Force killing and removing Jarvis containers...${NC}"
    docker compose kill
    docker compose rm -f
    echo -e "${GREEN}✅ Environment wiped clean.${NC}"

elif [ "$1" == "logs" ]; then
    echo -e "${CYAN}📜 Fetching live logs... (Press Ctrl+C to exit)${NC}"
    docker compose logs -f

else
    show_help
fi
